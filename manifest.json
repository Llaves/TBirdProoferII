{
  "manifest_version": 2,
  "name": "LLM Proofreader",
  "version": "2.1",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png"
  },
  "description": "An extension to proofread emails using multiple LLM providers (Google Gemini, OpenRouter).",
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": ["storage", "compose", "messagesRead", "tabs"],
  "browser_action": {
    "default_title": "LLM Proofreader",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png"
    }
  },
  "compose_action": {
    "default_title": "LLM Proofreader",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "applications": {
    "gecko": {
      "id": "LLMProofreader@thunderbird"
    }
  },
  "web_accessible_resources": [
    "manage_prompts.html",
    "manage_prompts.js",
    "add_prompt.html",
    "add_prompt.js",
    "view_key.html",
    "view_key.js",
    "suggestions.html",
    "suggestions.js",
    "waiting.html",
    "waiting.js",
    "error.html",
    "error.js"
  ]
}
